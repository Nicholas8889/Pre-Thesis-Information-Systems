generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CustomerStatus {
  Active
  Inactive
}

enum ProductStatus {
  Active
  Inactive
}

enum TransactionType {
  SALES_ORDER
  PRE_ORDER
}

enum SalesOrderStatus {
  Draft
  Confirmed
  Shipped
  Invoiced
  Cancelled
}

enum SalesOrderApprovalStatus {
  NotRequired
  Pending
  Approved
  Rejected
}

enum InvoiceStatus {
  Unpaid
  Partial
  Paid
  Overdue
  Cancelled
}

enum PaymentMethod {
  Cash
  BankTransfer
  Other
}

enum PaymentTermType {
  DEBIT
  CREDIT
}

enum FollowUpStatus {
  Planned
  Done
  Cancelled
}

enum CustomerInquiryStatus {
  Open
  Closed
  Cancelled
  ConvertedToPO
  ConvertedToSO
  Done
}

enum DeliveryNoteStatus {
  Draft
  Issued
  Delivered
  Cancelled
}

enum UserRole {
  ADMIN
  SALES
  MANAGER
}

enum UserStatus {
  Active
  Inactive
}

model User {
  id           String     @id @default(cuid()) @map("idUser")
  username     String     @unique
  passwordHash String
  displayName  String
  role         UserRole   @default(SALES)
  status       UserStatus @default(Active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AuditTrail {
  id               String   @id @default(cuid()) @map("idAuditTrail")
  actorUserId      String?
  actorUsername    String
  actorDisplayName String?
  actorRole        String
  moduleName       String
  entityType       String
  entityId         String
  transactionCode  String
  action           String
  changeSummary    String
  actionNote       String?
  oldValue         String?
  newValue         String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([moduleName])
  @@index([actorUsername])
  @@index([transactionCode])
}

model Customer {
  id           String         @id @default(cuid()) @map("idCustomer")
  name         String
  companyName  String
  phone        String
  email        String
  address      String
  customerType String
  status       CustomerStatus @default(Active)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  salesOrders      SalesOrder[]
  invoices         Invoice[]
  followUps        FollowUp[]
  productFollowUps CustomerProductFollowUp[]
  deliveryNotes    DeliveryNote[]
  inquiries        CustomerInquiry[]
}

model Product {
  id          String        @id @default(cuid()) @map("idProduct")
  productName String
  notes       String?
  basePrice   Int
  status      ProductStatus @default(Active)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  salesOrderItems SalesOrderItem[]
  inquiryItems    CustomerInquiryItem[]

  @@index([productName])
  @@index([status])
}

model SalesOrder {
  id                   String                   @id @default(cuid()) @map("idSalesOrder")
  orderNumber          String                   @unique
  poNumber             String?                  @unique
  transactionType      TransactionType          @default(SALES_ORDER)
  requiredDate         DateTime?
  poDocumentName       String?
  poDocumentStoredName String?
  poDocumentMimeType   String?
  customerId           String
  orderDate            DateTime
  status               SalesOrderStatus         @default(Draft)
  subtotal             Int
  total                Int
  paymentTermType      PaymentTermType          @default(DEBIT)
  creditTermMonths     Int?
  notes                String?
  approvalStatus       SalesOrderApprovalStatus @default(NotRequired)
  approvalRisk         String?
  approvalDecisionNote String?
  approvalDecidedAt    DateTime?
  approvalDecidedById  String?
  createdByUserId      String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  customer      Customer         @relation(fields: [customerId], references: [id])
  items         SalesOrderItem[]
  invoice       Invoice?
  deliveryNotes DeliveryNote[]
  customerInquiry CustomerInquiry?

  @@index([approvalStatus])
  @@index([transactionType])
  @@index([requiredDate])
}

model CustomerInquiry {
  id             String                @id @default(cuid()) @map("idCustomerInquiry")
  inquiryNumber  String                @unique
  customerId     String
  inquiryDate    DateTime              @default(now())
  neededBy       DateTime?
  status         CustomerInquiryStatus @default(Open)
  notes          String?
  statusNote     String?
  salesOrderId   String?               @unique
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  customer   Customer              @relation(fields: [customerId], references: [id])
  salesOrder SalesOrder?           @relation(fields: [salesOrderId], references: [id])
  items      CustomerInquiryItem[]

  @@index([customerId])
  @@index([status])
  @@index([inquiryDate])
}

model CustomerInquiryItem {
  id                String          @id @default(cuid()) @map("idCustomerInquiryItem")
  customerInquiryId String
  productId         String?
  itemName          String
  quantity          Int
  requestedPrice    Int?
  agreedPrice       Int?
  notes             String?

  customerInquiry CustomerInquiry @relation(fields: [customerInquiryId], references: [id], onDelete: Cascade)
  product         Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId])
}

model SalesOrderItem {
  id              String  @id @default(cuid()) @map("idSalesOrderItem")
  salesOrderId    String
  productId       String?
  itemName        String
  quantity        Int
  basePrice       Int     @default(0)
  markupPercent   Int     @default(0)
  discountPercent Int     @default(0)
  unitPrice       Int
  subtotal        Int

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId])
}

model Invoice {
  id               String          @id @default(cuid()) @map("idInvoice")
  invoiceNumber    String          @unique
  salesOrderId     String          @unique
  customerId       String
  issueDate        DateTime
  dueDate          DateTime
  totalAmount      Int
  paidAmount       Int             @default(0)
  remainingAmount  Int
  paymentTermType  PaymentTermType @default(DEBIT)
  creditTermMonths Int?
  status           InvoiceStatus   @default(Unpaid)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  salesOrder    SalesOrder     @relation(fields: [salesOrderId], references: [id])
  customer      Customer       @relation(fields: [customerId], references: [id])
  payments      Payment[]
  followUps     FollowUp[]
  deliveryNotes DeliveryNote[]
}

model Payment {
  id            String        @id @default(cuid()) @map("idPayment")
  invoiceId     String
  paymentDate   DateTime
  amount        Int
  paymentMethod PaymentMethod
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model FollowUp {
  id           String         @id @default(cuid()) @map("idFollowUp")
  customerId   String
  invoiceId    String?
  followUpDate DateTime
  status       FollowUpStatus @default(Planned)
  notes        String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])
}

model CustomerProductFollowUp {
  id          String   @id @default(cuid()) @map("idCustomerProductFollowUp")
  customerId  String
  contactDate DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, contactDate])
}

model DeliveryNote {
  id                 String             @id @default(cuid()) @map("idDeliveryNote")
  deliveryNoteNumber String             @unique
  invoiceId          String?
  salesOrderId       String?
  customerId         String
  recipientName      String
  recipientPhone     String
  recipientAddress   String
  deliveryDate       DateTime
  status             DeliveryNoteStatus @default(Draft)
  notes              String?
  receiverName       String?
  senderName         String?
  authorizedBy       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  invoice    Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  salesOrder SalesOrder?        @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  customer   Customer           @relation(fields: [customerId], references: [id])
  items      DeliveryNoteItem[]
}

model DeliveryNoteItem {
  id             String  @id @default(cuid()) @map("idDeliveryNoteItem")
  deliveryNoteId String
  productCode    String?
  itemName       String
  quantity       Int
  unit           String  @default("PCS")
  description    String?

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
}
